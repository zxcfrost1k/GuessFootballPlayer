<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"

    android:id="@+id/chapter"
    android:layout_width="match_parent"
    android:layout_height="match_parent"

    android:background="@drawable/bg_main"

    tools:context=".ChapterDefaultActivityRECAST">

    <TextView
        android:id="@+id/balanceTextView"

        android:layout_width="130dp"
        android:layout_height="29dp"

        android:background="@drawable/stl_transparent_10"

        android:textColor="@color/white"
        android:textSize="7pt"
        android:gravity="center_horizontal|center_vertical"
        android:fontFamily="serif"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.15"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.06" />

    <TextView
        android:id="@+id/userLevelTextView"

        android:layout_width="130dp"
        android:layout_height="29dp"

        android:background="@drawable/stl_transparent_10"

        android:textColor="@color/white"
        android:textSize="7pt"
        android:gravity="center_horizontal|center_vertical"
        android:fontFamily="serif"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.85"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.06" />

    <ImageButton
        android:id="@+id/buttonSelection"
        android:contentDescription="@string/selection"

        android:layout_width="35dp"
        android:layout_height="35dp"

        android:background="@null"
        android:scaleType="centerInside"
        android:src="@drawable/ic_ballot"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.07"

        tools:ignore="TouchTargetSizeCheck,SpeakableTextPresentCheck" />

    <ToggleButton
        android:id="@+id/toggleLoanButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/ic_loan_filter"
        android:checked="false"
        android:fontFamily="serif"
        android:textOff="@string/loan_off"
        android:textOn="@string/loan_on"
        android:textSize="6pt"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.12"
        tools:ignore="TouchTargetSizeCheck,TextSizeCheck" />

    <RelativeLayout
        android:id="@+id/selectionWindowRelative"

        android:layout_width="match_parent"
        android:layout_height="match_parent"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        android:background="@drawable/stl_transparent_20"
        android:visibility="gone"
        android:elevation="10dp"

        android:clickable="true"
        android:focusable="true">

        <androidx.cardview.widget.CardView
            android:id="@+id/selectionCardView"
            android:layout_width="300dp"
            android:layout_height="275dp"

            android:layout_centerInParent="true"

            app:cardBackgroundColor="#BFFFFFFF"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"

            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="240dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:background="@drawable/stl_text_white"
                    android:fontFamily="serif"
                    android:gravity="center"
                    android:text="@string/selectionWindow"
                    android:textColor="@color/black"
                    android:textSize="8pt"
                    tools:ignore="TextSizeCheck" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="40dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/stl_stars_background">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="StarRow">
                            <include layout="@layout/ch_layout_star" />
                        </LinearLayout>

                        <Button
                            android:id="@+id/buttonSelection1"
                            android:layout_width="80dp"
                            android:layout_height="26dp"
                            android:layout_marginStart="16dp"
                            android:background="@drawable/stl_transparent_15"
                            android:fontFamily="serif"
                            android:gravity="center"
                            android:text="@string/star1"
                            android:textColor="@color/white"
                            android:textSize="6.5pt"
                            tools:ignore="TextSizeCheck" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="17dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/stl_stars_background">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="StarRow">
                            <include layout="@layout/ch_layout_star" />
                            <include layout="@layout/ch_layout_star" />
                            <include layout="@layout/ch_layout_star" />
                        </LinearLayout>

                        <Button
                            android:id="@+id/buttonSelection2"
                            android:layout_width="80dp"
                            android:layout_height="26dp"
                            android:layout_marginStart="16dp"
                            android:background="@drawable/stl_transparent_15"
                            android:fontFamily="serif"
                            android:gravity="center"
                            android:text="@string/star3"
                            android:textColor="@color/white"
                            android:textSize="6.5pt"
                            tools:ignore="TextSizeCheck" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="17dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/stl_stars_background">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="StarRow">
                            <include layout="@layout/ch_layout_star" />
                            <include layout="@layout/ch_layout_star" />
                            <include layout="@layout/ch_layout_star" />
                            <include layout="@layout/ch_layout_star" />
                            <include layout="@layout/ch_layout_star" />
                        </LinearLayout>

                        <Button
                            android:id="@+id/buttonSelection3"
                            android:layout_width="80dp"
                            android:layout_height="26dp"
                            android:layout_marginStart="16dp"
                            android:background="@drawable/stl_transparent_15"
                            android:fontFamily="serif"
                            android:gravity="center"
                            android:text="@string/star5"
                            android:textColor="@color/white"
                            android:textSize="6.5pt"
                            tools:ignore="TextSizeCheck" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:gravity="center_horizontal"
        android:orientation="horizontal"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.6">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/linearLayoutUpTop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginTop="200dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">
    </LinearLayout>

    <LinearLayout
        android:id="@+id/linearLayoutUp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginTop="200dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">
    </LinearLayout>

    <LinearLayout
        android:id="@+id/linearLayoutLow"

        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        android:gravity="center"
        android:orientation="vertical"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.9">

        <!-- Первая строка кнопок -->
        <LinearLayout
            android:id="@+id/linearLayoutLow1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/button1"
                style="@style/buttonLetter"
                android:layout_width="48dp"
                android:layout_height="68dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_letters"
                android:text="A"
                tools:ignore="HardcodedText,VisualLintBounds" />

            <Button
                android:id="@+id/button2"
                style="@style/buttonLetter"
                android:layout_width="48dp"
                android:layout_height="68dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_letters"
                android:text="B"
                tools:ignore="HardcodedText" />

            <Button
                android:id="@+id/button3"
                style="@style/buttonLetter"
                android:layout_width="48dp"
                android:layout_height="68dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_letters"
                android:text="C"
                tools:ignore="HardcodedText" />

            <Button
                android:id="@+id/button4"
                style="@style/buttonLetter"
                android:layout_width="48dp"
                android:layout_height="68dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_letters"
                android:text="D"
                tools:ignore="HardcodedText" />

            <Button
                android:id="@+id/button5"
                style="@style/buttonLetter"
                android:layout_width="48dp"
                android:layout_height="68dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_letters"
                android:text="E"
                tools:ignore="HardcodedText" />

            <Button
                android:id="@+id/button6"
                style="@style/buttonLetter"
                android:layout_width="48dp"
                android:layout_height="68dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_letters"
                android:text="F"
                tools:ignore="HardcodedText" />

            <Button
                android:id="@+id/button7"
                style="@style/buttonLetter"
                android:layout_width="48dp"
                android:layout_height="68dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_letters"
                android:text="Q"
                tools:ignore="HardcodedText" />

            <Button
                android:id="@+id/button8"
                style="@style/buttonLetter"
                android:layout_width="48dp"
                android:layout_height="68dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_letters"
                android:text="V"
                tools:ignore="HardcodedText" />

            <Button
                android:id="@+id/button9"
                style="@style/buttonLetter"
                android:layout_width="48dp"
                android:layout_height="68dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_letters"
                android:text="G"
                tools:ignore="HardcodedText,VisualLintBounds" />

        </LinearLayout>

        <!-- Вторая строка кнопок -->
        <LinearLayout
            android:id="@+id/linearLayoutLow2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/button10"
                style="@style/buttonLetter"
                android:layout_width="48dp"
                android:layout_height="68dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_letters"
                android:text="H"
                tools:ignore="HardcodedText,TouchTargetSizeCheck,VisualLintBounds" />

            <Button
                android:id="@+id/button11"
                style="@style/buttonLetter"
                android:layout_width="48dp"
                android:layout_height="68dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_letters"
                android:text="I"
                tools:ignore="HardcodedText" />

            <Button
                android:id="@+id/button12"
                style="@style/buttonLetter"
                android:layout_width="48dp"
                android:layout_height="68dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_letters"
                android:text="J"
                tools:ignore="HardcodedText" />

            <Button
                android:id="@+id/button13"
                style="@style/buttonLetter"
                android:layout_width="48dp"
                android:layout_height="68dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_letters"
                android:text="K"
                tools:ignore="HardcodedText" />

            <Button
                android:id="@+id/button14"
                style="@style/buttonLetter"
                android:layout_width="48dp"
                android:layout_height="68dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_letters"
                android:text="L"
                tools:ignore="HardcodedText" />

            <Button
                android:id="@+id/button15"
                style="@style/buttonLetter"
                android:layout_width="48dp"
                android:layout_height="68dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_letters"
                android:text="M"
                tools:ignore="HardcodedText" />

            <Button
                android:id="@+id/button16"
                style="@style/buttonLetter"
                android:layout_width="48dp"
                android:layout_height="68dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_letters"
                android:text="G"
                tools:ignore="HardcodedText,DuplicateSpeakableTextCheck" />

            <Button
                android:id="@+id/button17"
                style="@style/buttonLetter"
                android:layout_width="48dp"
                android:layout_height="68dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_letters"
                android:text="G"
                tools:ignore="HardcodedText,TouchTargetSizeCheck,VisualLintBounds" />
        </LinearLayout>
    </LinearLayout>

    <RelativeLayout
        android:id="@+id/successWindowRelative"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#95FFFFFF"
        android:visibility="gone"
        android:elevation="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/successImage"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_centerInParent="true"
            android:contentDescription="@string/success"
            android:src="@drawable/ic_star"
            tools:ignore="MissingConstraints" />

        <Button
            android:id="@+id/buttonNext"
            android:text="Next"

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:layout_below="@+id/successImage"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp"

            android:fontFamily="serif"
            android:clickable="false"
            android:background="@drawable/btn_default"

            tools:ignore="HardcodedText" />
    </RelativeLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
